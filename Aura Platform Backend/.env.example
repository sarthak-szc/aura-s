# Copy to .env and fill in values
ENV=development
DEBUG=true

MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=aura-cluster
MONGO_DB=aura_db

JWT_SECRET=generate-a-long-random-secret-here
JWT_EXPIRE_HOURS=24

CORS_ORIGINS=http://localhost:3000,https://aura-frontend-mu.vercel.app

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_BLOB_CONTAINER=aura-uploads

# Azure OpenAI — add when key is available
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

ADMIN_SETUP_ENABLED=true
DEFAULT_ADMIN_EMAIL=admin@aura.com
DEFAULT_ADMIN_PASSWORD=ChangeMeOnFirstLogin!
